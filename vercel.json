{
  "builds": [
    {
      "src": "greatkart/wsgi.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "15mb",
        "buildCommand": "pip install -r requirements.txt"
      }
    }
  ],
  "routes": [
    {
      "src": "/static/(.*)",
      "dest": "/static/"
    },
    {
      "src": "/media/(.*)",
      "dest": "/media/"
    },
    {
      "src": "/(.*)",
      "dest": "greatkart/wsgi.py"
    }
  ],
  "env": {
    "DJANGO_SETTINGS_MODULE": "greatkart.settings"
  }
}